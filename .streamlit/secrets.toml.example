# Copie este arquivo para .streamlit/secrets.toml e preencha com suas credenciais.
# Em produção (Streamlit Cloud), defina os mesmos campos no painel "Secrets".

# Senha de acesso ao app (obrigatória).
APP_PASSWORD = "troque-esta-senha"

# Nome da planilha Google Sheets onde os dados serão persistidos.
SPREADSHEET_NAME = "Banco_Monitor_Financeiro"

# JSON da Service Account do Google em UMA ÚNICA STRING (entre aspas triplas).
# Gere em: console.cloud.google.com -> IAM -> Service Accounts -> Keys -> Add Key (JSON)
# Depois compartilhe a planilha com o e-mail "client_email" do JSON.
GOOGLE_JSON = """
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "..."
}
"""
